---
import { TooltipProvider } from "@/components/ui/tooltip";
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Spin the Bottle — Party Game",
  description = "A fun, animated spin the bottle party game. Add players, spin the bottle, and let fate decide!",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <TooltipProvider client:load><slot /></TooltipProvider>
  </body>
</html>
